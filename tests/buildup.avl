function Compute_SSSP (Graph g,propNode<int,g> dist, propEdge<int,g> weight, Node src) {


    propNode <bool,g> modified_nxt;
    propNode <bool,g> modified;

    g.attachNodeProperty(modified = False, modified_nxt = False, dist = INF); # dist=INF); #, modified = False, modified_nxt = False );

# g.attachNodeProperty(dist=INF); g.attachNodeProperty(modified=False); g.attachNodeProperty(modified_nxt=False);

	   src.dist=0;

	   src.modified = True; 

	    int a = True;
	   int finished =False;

	   # <src.dist, src.modified_nxt> = <Min (src.dist, 0), True>;
	   fixedPoint until (finished:!modified) {
	#
	forall (v in g.nodes().filter(v.modified == True)) {
	# v.dist = 1;

	   # <src.dist, src.modified_nxt> = <Min (src.dist, 0), True>;
	# <v.dist, v.modified_nxt> = <Min (v.dist, 0), True>; 
	    forall (nbr in g.neighbors(v)) {          
	    # nbr.dist = 2;

		edge e = g.get_edge(v, nbr);



		# if (v.dist + e.weight > nbr.dist) {} else {}

		<nbr.dist,nbr.modified_nxt> = <Min (nbr.dist, v.dist + e.weight), True>;
	    }
	}
	modified = modified_nxt;
	g.attachNodeProperty(modified_nxt = False);
	   }
    return 2;
}
